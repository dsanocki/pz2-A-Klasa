@model Aklasa.Models.Druzyna

@{
    ViewData["Title"] = "Details";
}

<h1>Szczegóły</h1>

<div>
    <h4>Drużyna</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NazwaKlubu)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NazwaKlubu)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IloscMeczy)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IloscMeczy)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IloscZwyciestw)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IloscZwyciestw)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IloscRemisow)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IloscRemisow)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IloscPorazek)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IloscPorazek)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.BramkiZdobyte)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BramkiZdobyte)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.BramkiStracone)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BramkiStracone)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.BilansBramkowy)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BilansBramkowy)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Punkty)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Punkty)
        </dd>
    </dl>
</div>
<div>
    @if (User.Identity.IsAuthenticated)
    {
        <a asp-action="Edit" asp-route-id="@Model?.IdDruzyny">Edytuj</a>
    }
    <a asp-action="Index">Wróć do listy</a>
</div>
<hr />

<h4>Zawodnicy w tej drużynie</h4>

@if (Model.Zawodnicy != null && Model.Zawodnicy.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Imię</th>
                <th>Nazwisko</th>
                <th>Bramki</th>
                <th>Asysty</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var z in Model.Zawodnicy)
        {
            <tr>
                <td>@z.Imie</td>
                <td>@z.Nazwisko</td>
                <td>@z.IloscBramek</td>
                <td>@z.IloscAsyst</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>Brak zawodników w tej drużynie.</p>
}