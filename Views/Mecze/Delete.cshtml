@model Aklasa.Models.Mecz

@{
    ViewData["Title"] = "Delete";
}

<h1>Usuń</h1>

<h3>Czy na pewno chcesz usunąć?</h3>
<div>
    <h4>Mecz</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Gospodarz)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Gospodarz.NazwaKlubu)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Gosc)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Gosc.NazwaKlubu)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DataMeczu)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DataMeczu)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.BramkiGospodarzy)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BramkiGospodarzy)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.BramkiGosci)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BramkiGosci)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="IdMeczu" />
        <input type="submit" value="Usuń" class="btn btn-danger" /> |
        <a asp-action="Index">Wróć do listy</a>
    </form>
</div>
