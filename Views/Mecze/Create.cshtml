@model Aklasa.Models.Mecz

@{
    ViewData["Title"] = "Create";
}

<h1>Dodaj</h1>

<h4>Mecz</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="GospodarzId" class="control-label"></label>
                <select asp-for="GospodarzId" class ="form-control" asp-items="ViewBag.GospodarzId"></select>
            </div>
            <div class="form-group">
                <label asp-for="GoscId" class="control-label"></label>
                <select asp-for="GoscId" class ="form-control" asp-items="ViewBag.GoscId"></select>
            </div>
            <div class="form-group">
                <label asp-for="BramkiGospodarzy" class="control-label"></label>
                <input asp-for="BramkiGospodarzy" class="form-control" />
                <span asp-validation-for="BramkiGospodarzy" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BramkiGosci" class="control-label"></label>
                <input asp-for="BramkiGosci" class="form-control" />
                <span asp-validation-for="BramkiGosci" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DataMeczu" class="control-label"></label>
                <input asp-for="DataMeczu" class="form-control" />
                <span asp-validation-for="DataMeczu" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Dodaj" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Wróć do listy</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
