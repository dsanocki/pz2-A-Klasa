@model Aklasa.Models.Transfer

@{
    ViewData["Title"] = "Delete";
}

<h1>Usuń</h1>

<h3>Czy na pewno chcesz usunąć?</h3>
<div>
    <h4>Transfer</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Zawodnik)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Zawodnik.Nazwisko)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DruzynaOd)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DruzynaOd.NazwaKlubu)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DruzynaDo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DruzynaDo.NazwaKlubu)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DataTransferu)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DataTransferu)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="IdTransferu" />
        <input type="submit" value="Usuń" class="btn btn-danger" /> |
        <a asp-action="Index">Wróć do listy</a>
    </form>
</div>
